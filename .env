# App
APP_NAME=ArbiCore
DEBUG=false
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:12345@localhost:5432/arbicore
# If you don't have PostgreSQL yet, use SQLite for testing (but for production use PostgreSQL)
# DATABASE_URL=sqlite+aiosqlite:///./arbicore.db

# Security (generate a random secret key)
SECRET_KEY=fastapi-insecure-eyp!v1ou8*t5%1@y&5df10

# Arbitrage
ARBITRAGE_CHECK_INTERVAL_SECONDS=10
ARBITRAGE_MIN_PROFIT_PERCENT=0.001

# Exchange API credentials (only needed for live mode)
WALLEX_API_KEY=your_wallex_api_key
WALLEX_API_SECRET=your_wallex_secret   # if required
NOBITEX_API_KEY=your_nobitex_email
NOBITEX_API_SECRET=your_nobitex_password
BITPIN_API_KEY=your_bitpin_api_key
BITPIN_API_SECRET=your_bitpin_secret_key

# Optional
# REDIS_URL=redis://localhost:6379